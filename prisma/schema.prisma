generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  FLAGGED
}

enum AppointmentStatus {
  HOLD
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum RecordType {
  DIAGNOSIS
  PRESCRIPTION
  LAB_REPORT
  IMAGING
  VACCINATION
  ALLERGY
  EMERGENCY
  CONSULTATION
  INSURANCE
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  phone              String?            @unique
  passwordHash       String
  role               Role               @default(PATIENT)
  avatarUrl          String?
  verificationStatus VerificationStatus @default(PENDING)
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  mfaEnabled         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  patientProfile     PatientProfile?
  doctorProfile      DoctorProfile?
  otps               VerificationOtp[]
  notifications      Notification[]
  aiConsultations    AiConsultation[]
  oauthAccounts      OauthAccount[]

  @@index([role, verificationStatus])
}

model OauthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model PatientProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  dateOfBirth      DateTime?
  bloodGroup       String?
  allergies        String[]
  emergencyContact Json?
  insurance        Json?
  aadhaarHash      String?
  passportHash     String?
  faceVectorHash   String?
  healthScore      Int             @default(72)
  qrCode           String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  medicalRecords   MedicalRecord[]
  reports          Report[]
  prescriptions    Prescription[]
  reviews          Review[]

  @@index([healthScore])
}

model DoctorProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  licenseNumber      String             @unique
  specialization     String
  experienceYears    Int
  consultationFee    Int
  bio                String
  education          String[]
  languages          String[]
  rating             Float              @default(4.8)
  reviewCount        Int                @default(0)
  isEmergencyReady   Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicId           String?
  clinic             Clinic?            @relation(fields: [clinicId], references: [id])
  slots              Slot[]
  appointments       Appointment[]
  prescriptions      Prescription[]
  reviews            Review[]

  @@index([specialization, rating])
  @@index([verificationStatus])
}

model Clinic {
  id                 String             @id @default(cuid())
  name               String
  address            String
  city               String
  state              String
  country            String             @default("India")
  latitude           Float?
  longitude          Float?
  phone              String?
  imageUrl           String?
  timings            Json?
  emergencyAvailable Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  doctors            DoctorProfile[]

  @@index([city, verificationStatus])
  @@index([latitude, longitude])
}

model Slot {
  id           String        @id @default(cuid())
  doctorId     String
  startsAt     DateTime
  endsAt       DateTime
  capacity     Int           @default(1)
  bookedCount  Int           @default(0)
  isBlocked    Boolean       @default(false)
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([doctorId, startsAt])
  @@index([startsAt, isBlocked])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  slotId          String
  status          AppointmentStatus @default(CONFIRMED)
  reason          String
  aiTriageSummary String?
  urgencyLevel    String?
  riskScore       Int?
  queueNumber     Int?
  meetingUrl      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  patient         PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          DoctorProfile     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  slot            Slot              @relation(fields: [slotId], references: [id])

  @@unique([slotId, patientId])
  @@index([doctorId, status])
  @@index([patientId, createdAt])
}

model MedicalRecord {
  id            String         @id @default(cuid())
  patientId     String
  doctorId      String?
  type          RecordType
  title         String
  summary       String
  occurredAt    DateTime
  metadata      Json?
  aiSummary     String?
  verified      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  patient       PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, occurredAt])
  @@index([type, verified])
}

model Report {
  id                 String             @id @default(cuid())
  patientId          String
  title              String
  fileUrl            String
  fileType           String
  ocrText            String?
  hospitalName       String?
  labName            String?
  verificationStatus VerificationStatus @default(PENDING)
  aiConfidence       Float              @default(0)
  flags              String[]
  uploadedAt         DateTime           @default(now())
  patient            PatientProfile     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, uploadedAt])
  @@index([verificationStatus, aiConfidence])
}

model Prescription {
  id              String         @id @default(cuid())
  patientId       String
  doctorId        String
  diagnosis       String
  medicines       Json
  instructions    String
  followUpAt      DateTime?
  createdAt       DateTime       @default(now())
  patient         PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          DoctorProfile  @relation(fields: [doctorId], references: [id])

  @@index([patientId, createdAt])
  @@index([doctorId, createdAt])
}

model AiConsultation {
  id           String   @id @default(cuid())
  userId       String
  prompt       String
  response     String
  riskScore    Int?
  urgencyLevel String?
  model        String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model Review {
  id        String         @id @default(cuid())
  patientId String
  doctorId  String
  rating    Int
  comment   String
  createdAt DateTime       @default(now())
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([patientId, doctorId])
  @@index([doctorId, rating])
}

model VerificationOtp {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  purpose   String
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
}
